{
  "name": "vjudge-for-vscode",
  "displayName": "VJudge for VSCode",
  "description": "Efficiently solve and submit VJudge problems without leaving your editor.",
  "version": "0.0.1",
  "publisher": "vjudge",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vjudge-for-vscode.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "vjudge-for-vscode.loginVjudge",
        "title": "VJudge 登录"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vjudge",
          "title": "VJudge",
          "icon": "media/logo.svg"
        }
      ]
    },
    "views": {
      "vjudge": [
        {
          "id": "vjudgeView",
          "icon": "media/logo.svg",
          "name": "VJudge"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "cheerio": "^1.2.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}
